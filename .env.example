# Hero video (optional)
VITE_HERO_VIDEO_URL=

# ─── Backend API Keys ─── #

# Google Gemini API Key
# Get it from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Airtable Personal Access Token
# Get it from: https://airtable.com/create/tokens
AIRTABLE_API_KEY=your_airtable_pat_here

# Airtable Base ID (starts with "app...")
# Find it in the URL when you open your base: https://airtable.com/appXXXXXXXXXXXXXX
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Airtable Table Name (default: "Leads")
AIRTABLE_TABLE_NAME=Leads
